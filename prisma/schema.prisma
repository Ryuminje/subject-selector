// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 학교 하나 = 테넌트 하나

model School {
  id       String @id @default(cuid())
  name     String
  joinCode String @unique

  // 업로드된 시간표 원본 (teachers/days/periods/tableData 형태의 JSON — ScheduleData 참고)
  scheduleData       String?
  scheduleUploadedAt DateTime?

  // 전체 교사 공통 협의회 불가 요일/교시 (JSON: Record<day, number[]>)
  globalMeetingBlocks String @default("{}")

  // 교과군 그룹 목록 (JSON: string[]) — 교사 목록 관리 화면에서 관리자가 추가/삭제
  departmentGroups String @default("[\"국어\",\"영어\",\"수학\",\"사회\",\"과학\"]")

  // 교체 자체가 금지된 과목명 목록 (JSON: string[]) — 시간 이동(교체)이 아예 불가능한 과목
  blockedSubjects String @default("[]")

  // 교체·대강 모두 완전히 금지된 교사명 목록 (JSON: string[])
  blockedTeachers String @default("[]")

  // 연수 이수증 수거용 Gemini API 키 — 관리자가 등록하면 같은 학교 전원이 사용 (평문 저장, joinCode와 동일한 신뢰 수준)
  geminiApiKey String?

  createdAt DateTime @default(now())

  teachers                 Teacher[]
  trainingTitles           TrainingTitle[]
  trainingCertificates     TrainingCertificate[]
  signSessions             SignSession[]
  certificateRosterExtras  CertificateRosterExtra[]
  certificateRosterPresets CertificateRosterPreset[]
}

// 시간표에 등장하는 교사 한 명 (로그인 계정 유무와 무관하게 존재 — 업로드 시 이름으로 자동 upsert)

model Teacher {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name String

  // 교과군 (기존 "설정" 시트 I~J열 대체)
  department String?

  // 고정 교체 불가 요일/교시 (기존 "설정" 시트 A~C열 대체, JSON: Record<day, number[]>)
  fixedBlockDays String @default("{}")

  // 오늘 결근/출장 등 임시 설정 (기존 브라우저 localStorage 대체, 학교 전체 공유, JSON: Record<day, number[]>)
  tempBlockDays String @default("{}")

  @@unique([schoolId, name])
}

// 연수 이수증 수거 — 담당 선생님이 등록한 연수 제목. 등록된 연수만 전체 교사가 제출할 수 있고,
// 제출 현황(일괄확인)은 그 연수를 등록한 담당 선생님과 관리자만 조회할 수 있습니다.

model TrainingTitle {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title             String
  registeredByName  String  // 담당 선생님 이름 — 제출 시점과 동일하게 session 기준으로 서버가 채움
  rosterSnapshot    String? // JSON string[] — 이 연수 전용 참여명단. null이면 getCertificateRoster() 기본값으로 대체
  createdAt         DateTime @default(now())

  @@unique([schoolId, title])
  @@index([schoolId, registeredByName])
}

// 연수 이수증 수거 — 제출된 이수증 한 건 (teacherName은 자유 입력이 아니라 제출 시점 session.user 기준으로 서버가 채움)

model TrainingCertificate {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teacherName   String
  trainingTitle String
  number        String // 이수번호
  institution   String // 이수기관
  certDate      String // 이수날짜 (Gemini 추출값, 자유 텍스트로 유지)

  fileName  String
  mimeType  String
  fileBytes Bytes // Postgres bytea — 원본 파일 바이트

  createdAt DateTime @default(now())

  @@index([schoolId, teacherName])
  @@index([schoolId, trainingTitle])
}

// 연수 이수증 수거 — QR 서명 세션 (단일 연수 또는 복수 연수 그룹)

model SignSession {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  trainingTitles   String  // JSON string[] — 단일 1개, 복수연수 2개 이상
  rosterSnapshot   String  // JSON string[] — 세션 생성 시점 명단 스냅샷(합집합). 프리셋/전체 기본 명시 선택 시 그 명단, 아니면 titleRosters 합집합
  titleRosters     String? // JSON Record<title, string[]> — 세션 생성 시점 "연수별" 명단 스냅샷. roster를 명시적으로 지정(전체 기본/프리셋 선택)한 세션은 null 유지
  rosterPresetName String? // 이 세션 생성에 사용한 CertificateRosterPreset.name (없으면 "전체 명단" 기본 경로)
  locked           Boolean  @default(false)
  createdAt        DateTime @default(now())
  createdByUserId  String   // better-auth User.id (조회용, @relation 없음 — User 모델 손대지 않는 원칙)

  signatures SignSessionSignature[]

  @@index([schoolId, createdAt])
}

// 연수 이수증 수거 — 세션 내 교사 1명당 서명 1건
// (복수 연수 세션이어도 서명은 한 번만 — 그 서명이 세션의 모든 연수 제목에 동시 적용됨, 원본 Code.gs의
// submitSignature가 sheetNameList.forEach로 같은 서명 이미지를 모든 연수 시트에 동시 기록하던 것과 동일한 동작)

model SignSessionSignature {
  id        String      @id @default(cuid())
  sessionId String
  session   SignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  teacherName  String
  signaturePng Bytes

  signedAt DateTime @default(now())

  @@unique([sessionId, teacherName])
  @@index([sessionId])
}

// 연수 이수증 수거 — 시간표(Teacher)에 없는 인원(행정직원 등)을 일괄확인/QR 서명 명단에만 추가로 포함시키기 위한 명단.
// 시간표 교체 도우미(SwapTab)는 School.scheduleData.teachers를 기준으로 하므로 이 명단은 영향을 주지 않습니다.

model CertificateRosterExtra {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name      String
  addedBy   String // 추가한 관리자 이름 (참고용 — 삭제 권한은 관리자 전원에게 있음)
  createdAt DateTime @default(now())

  @@unique([schoolId, name])
}

// 연수 이수증 수거 — 용도별로 이름 붙여 저장해두고 재사용하는 명단 프리셋(예: "전체 교직원", "부장단만").
// names는 드래그 앤 드롭으로 정한 순서를 그대로 보존하는 JSON string[] — 재정렬 없음, 저장된 순서가 곧 서명부 순서.

model CertificateRosterPreset {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name      String
  names     String // JSON string[] — 순서 유지된 이름 목록
  createdBy String // 만든 관리자 이름 (참고용)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId, updatedAt])
}

// 로그인 계정(user/session/account/verification)은 better-auth CLI(`npx auth generate`)가
// 이 파일에 직접 추가합니다 — 이 아래에 생성된 모델은 손으로 수정하지 말고,
// schoolId/role/teacherId 같은 앱 전용 필드는 src/lib/auth.ts의 user.additionalFields로 정의하세요.

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String
  schoolId      String
  teacherId     String?
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
